{
  "name": "@levnikolaevich/hex-graph-mcp",
  "version": "0.3.0",
  "type": "module",
  "description": "Deterministic layered code graph MCP server. Indexes codebases into a SQLite graph via tree-sitter AST, canonical symbol identities, hashes, and semantic overlays for navigation, architecture, clones, references, implementations, and flow analysis.",
  "main": "server.mjs",
  "bin": {
    "hex-graph-mcp": "server.mjs"
  },
  "files": [
    "server.mjs",
    "benchmark/",
    "lib/",
    "README.md"
  ],
  "scripts": {
    "start": "node server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test test/smoke.mjs",
    "check": "node --check server.mjs",
    "benchmark": "node benchmark/index.mjs",
    "benchmark:diagnostic": "node benchmark/index.mjs --diagnostics"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "better-sqlite3": "^12.0.0",
    "chokidar": "^4.0.0",
    "picomatch": "^4.0.3",
    "tree-sitter-wasms": "^0.1.0",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.25.0"
  },
  "author": "Lev Nikolaevich <https://github.com/levnikolaevich>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/levnikolaevich/claude-code-skills/issues"
  },
  "keywords": [
    "mcp",
    "codegraph",
    "knowledge-graph",
    "tree-sitter",
    "code-intelligence",
    "blast-radius",
    "dependency-graph",
    "model-context-protocol",
    "claude",
    "ai",
    "llm",
    "coding-agent",
    "code-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/levnikolaevich/claude-code-skills",
    "directory": "mcp/hex-graph-mcp"
  },
  "homepage": "https://github.com/levnikolaevich/claude-code-skills/tree/master/mcp/hex-graph-mcp",
  "devDependencies": {
    "eslint": "^10.1.0"
  }
}
