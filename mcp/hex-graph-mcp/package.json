{
  "name": "@levnikolaevich/hex-graph-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "Code knowledge graph MCP server. Indexes codebases into SQLite graph via tree-sitter AST. 7 tools: index_project, search_symbols, get_impact, trace_calls, get_context, get_architecture, watch_project.",
  "main": "server.mjs",
  "bin": {
    "hex-graph-mcp": "server.mjs"
  },
  "files": [
    "server.mjs",
    "benchmark.mjs",
    "lib/",
    "README.md"
  ],
  "scripts": {
    "start": "node server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test test/",
    "check": "node --check server.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "better-sqlite3": "^12.0.0",
    "chokidar": "^4.0.0",
    "tree-sitter-wasms": "^0.1.0",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.25.0"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "codegraph",
    "knowledge-graph",
    "tree-sitter",
    "code-intelligence",
    "blast-radius",
    "dependency-graph",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/levnikolaevich/claude-code-skills",
    "directory": "mcp/hex-graph-mcp"
  },
  "homepage": "https://github.com/levnikolaevich/claude-code-skills/tree/master/mcp/hex-graph-mcp",
  "devDependencies": {
    "eslint": "^10.1.0"
  }
}
