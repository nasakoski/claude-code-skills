{
  "version": "2.0.0",
  "agents": {
    "gemini": {
      "name": "Gemini CLI",
      "command": "gemini",
      "args": ["-p", ""],
      "env_override": {"GOOGLE_CLOUD_PROJECT": ""},
      "timeout_seconds": 300,
      "skill_groups": ["200"],
      "health_check": "gemini --version"
    },
    "codex": {
      "name": "Codex CLI",
      "command": "codex",
      "args": ["exec"],
      "env_override": {},
      "timeout_seconds": 600,
      "skill_groups": ["300"],
      "health_check": "codex --version"
    },
    "codex-review": {
      "name": "Codex CLI (Review Mode)",
      "command": "codex",
      "args": ["exec", "--json", "--full-auto", "-C", "{cwd}", "-o", "{output_file}"],
      "env_override": {},
      "timeout_seconds": 0,
      "skill_groups": ["311", "512"],
      "health_check": "codex --version"
    },
    "gemini-review": {
      "name": "Gemini 3 Flash (Review Mode)",
      "command": "gemini",
      "args": ["--yolo", "-m", "gemini-3-flash-preview", "--output-format", "json", "-p", ""],
      "env_override": {"GOOGLE_CLOUD_PROJECT": ""},
      "timeout_seconds": 0,
      "skill_groups": ["311", "512"],
      "health_check": "gemini --version"
    }
  }
}
