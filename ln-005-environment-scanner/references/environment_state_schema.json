{
  "$id": "environment_state_v1",
  "type": "object",
  "required": ["$schema", "scanned_at", "tools", "git", "platform"],
  "properties": {
    "$schema": { "const": "environment_state_v1" },
    "scanned_at": { "type": "string", "format": "date-time" },
    "tools": {
      "type": "object",
      "required": ["linear", "ref", "context7", "hashline_edit", "codex", "gemini", "git_worktree"],
      "properties": {
        "linear": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "team_id": { "type": "string" },
            "detail": { "type": "string" }
          }
        },
        "ref": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "detail": { "type": "string" }
          }
        },
        "context7": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "detail": { "type": "string" }
          }
        },
        "hashline_edit": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "detail": { "type": "string" }
          }
        },
        "codex": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "version": { "type": "string" },
            "detail": { "type": "string" }
          }
        },
        "gemini": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "version": { "type": "string" },
            "detail": { "type": "string" }
          }
        },
        "git_worktree": {
          "type": "object",
          "required": ["available"],
          "properties": {
            "available": { "type": "boolean" },
            "disabled": { "type": "boolean" },
            "detail": { "type": "string" }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "required": ["default_branch"],
      "properties": {
        "default_branch": { "type": "string" }
      }
    },
    "platform": {
      "type": "object",
      "required": ["os", "shell"],
      "properties": {
        "os": { "type": "string", "enum": ["win32", "darwin", "linux"] },
        "shell": { "type": "string" }
      }
    }
  }
}
