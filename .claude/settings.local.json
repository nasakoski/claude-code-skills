{
  "permissions": {
    "allow": [
      "mcp__Ref",
      "mcp__context7",
      "mcp__hex-line",
      "mcp__hex-ssh",
      "mcp__hex-graph",
      "WebSearch",
      "Web Fetch",
      "Read",
      "Skill",
      "Bash",
      "Bash(node build-presentation.js:*)",
      "Bash(ls:*)",
      "WebFetch(domain:claudefa.st)",
      "WebFetch(domain:addyosmani.com)",
      "WebFetch(domain:ronie.medium.com)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "disableAllHooks": false,
  "outputStyle": "Explanatory",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node mcp/hex-line-mcp/hook.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node mcp/hex-line-mcp/hook.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node mcp/hex-line-mcp/hook.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
